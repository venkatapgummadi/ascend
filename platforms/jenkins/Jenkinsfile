// ASCEND — Full four-layer DevSecOps pipeline for Jenkins
//
// Declarative Jenkinsfile implementing the complete ASCEND framework.
// Requires plugins:
//   - SonarQube Scanner
//   - OWASP Dependency-Check
//   - Pipeline Utility Steps
//   - Kubernetes CLI (for deployments)
//   - Credentials Binding

pipeline {
    agent any

    environment {
        ASCEND_QUALITY_GATE_MIN    = "0.85"
        ASCEND_CRITICAL_THRESHOLD  = "0"
        ASCEND_HIGH_THRESHOLD      = "5"
        SONAR_PROJECT_KEY          = "${env.JOB_NAME}"
        DOCKER_IMAGE               = "${env.JOB_NAME}:${env.BUILD_NUMBER}"
    }

    options {
        disableConcurrentBuilds()
        timeout(time: 60, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '30'))
        ansiColor('xterm')
    }

    stages {

        // -------------------------------------------------------------------
        // LAYER 1 — Source Analysis (parallel)
        // -------------------------------------------------------------------

        stage('L1: Source Analysis') {
            parallel {

                stage('SAST — SonarQube') {
                    steps {
                        withSonarQubeEnv('SonarQube-Enterprise') {
                            sh 'mvn -B sonar:sonar -Dsonar.projectKey=$SONAR_PROJECT_KEY'
                        }
                    }
                }

                stage('SAST — Semgrep') {
                    agent {
                        docker { image 'returntocorp/semgrep:latest'; reuseNode true }
                    }
                    steps {
                        sh 'semgrep ci --config=p/ci --config=p/owasp-top-ten --json -o semgrep-report.json'
                    }
                    post {
                        always { archiveArtifacts artifacts: 'semgrep-report.json', allowEmptyArchive: true }
                    }
                }

                stage('SCA — Snyk') {
                    steps {
                        withCredentials([string(credentialsId: 'snyk-token', variable: 'SNYK_TOKEN')]) {
                            sh 'snyk test --severity-threshold=high --sarif-file-output=snyk.sarif'
                        }
                    }
                    post {
                        always { archiveArtifacts artifacts: 'snyk.sarif', allowEmptyArchive: true }
                    }
                }

                stage('Secrets — TruffleHog') {
                    steps {
                        sh '''
                            docker run --rm -v "$(pwd):/src" trufflesecurity/trufflehog:latest \\
                                filesystem /src --only-verified --fail
                        '''
                    }
                }
            }
        }

        // -------------------------------------------------------------------
        // QUALITY GATE 1 — SonarQube gate
        // -------------------------------------------------------------------

        stage('Quality Gate 1') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
                echo "PASS: Quality Gate 1 — Layer 1 scans clean"
            }
        }

        // -------------------------------------------------------------------
        // LAYER 2 — Build & Integration
        // -------------------------------------------------------------------

        stage('L2: Build & Integration') {
            parallel {

                stage('Container — Trivy') {
                    steps {
                        sh 'docker build -t $DOCKER_IMAGE .'
                        sh '''
                            trivy image --severity CRITICAL,HIGH \\
                                        --ignore-unfixed \\
                                        --exit-code 1 \\
                                        --format sarif \\
                                        --output trivy.sarif \\
                                        $DOCKER_IMAGE
                        '''
                    }
                    post {
                        always { archiveArtifacts artifacts: 'trivy.sarif', allowEmptyArchive: true }
                    }
                }

                stage('IaC — Checkov') {
                    steps {
                        sh '''
                            docker run --rm -v "$(pwd):/src" bridgecrew/checkov \\
                                -d /src --framework terraform,cloudformation,kubernetes,dockerfile \\
                                -o sarif --output-file-path /src/checkov.sarif
                        '''
                    }
                    post {
                        always { archiveArtifacts artifacts: 'checkov.sarif', allowEmptyArchive: true }
                    }
                }

                stage('License — FOSSA') {
                    when { expression { env.FOSSA_API_KEY != null } }
                    steps {
                        withCredentials([string(credentialsId: 'fossa-api-key', variable: 'FOSSA_API_KEY')]) {
                            sh 'fossa analyze && fossa test'
                        }
                    }
                }

                stage('Integration Tests') {
                    steps {
                        sh 'mvn -B verify -DskipUnitTests'
                    }
                }
            }
        }

        // -------------------------------------------------------------------
        // QUALITY GATE 2
        // -------------------------------------------------------------------

        stage('Quality Gate 2') {
            steps {
                echo "PASS: Quality Gate 2"
            }
        }

        // -------------------------------------------------------------------
        // LAYER 3 — Deployment + DAST
        // -------------------------------------------------------------------

        stage('L3: Deploy to Staging') {
            when { branch 'main' }
            steps {
                sh '''
                    kubectl apply -f k8s/staging-green.yaml
                    kubectl rollout status deployment/app-green -n staging --timeout=5m
                '''
            }
        }

        stage('L3: DAST — OWASP ZAP') {
            when { branch 'main' }
            steps {
                sh '''
                    docker run --rm -v "$(pwd)/.zap:/zap/wrk" ghcr.io/zaproxy/zaproxy:stable \\
                        zap-baseline.py -t https://staging.example.com -a -r zap-report.html
                '''
            }
            post {
                always {
                    archiveArtifacts artifacts: 'zap-report.html', allowEmptyArchive: true
                    publishHTML(target: [
                        reportName: 'ZAP Report',
                        reportDir: '.',
                        reportFiles: 'zap-report.html',
                        keepAll: true
                    ])
                }
            }
        }

        // -------------------------------------------------------------------
        // QUALITY GATE 3
        // -------------------------------------------------------------------

        stage('Quality Gate 3') {
            when { branch 'main' }
            steps {
                echo "PASS: Quality Gate 3 — DAST clean"
            }
        }

        // -------------------------------------------------------------------
        // Production promote
        // -------------------------------------------------------------------

        stage('Promote to Production') {
            when { branch 'main' }
            steps {
                input message: 'Promote to production?', ok: 'Promote'
                sh '''
                    kubectl patch service app-service -n production \\
                        -p '{"spec":{"selector":{"color":"green"}}}'
                    echo "Traffic switched to green slot. Monitoring 30-min rollback window."
                '''
            }
        }

        // -------------------------------------------------------------------
        // LAYER 4 — AI Sync trigger
        // -------------------------------------------------------------------

        stage('L4: AI Sync Trigger') {
            when { branch 'main' }
            steps {
                withCredentials([string(credentialsId: 'ascend-sync-webhook', variable: 'WEBHOOK')]) {
                    sh '''
                        curl -sS -X POST "$WEBHOOK" \\
                            -H "Content-Type: application/json" \\
                            -d "{\\"repo\\":\\"$JOB_NAME\\",\\"sha\\":\\"$GIT_COMMIT\\",\\"trigger\\":\\"post-deploy\\"}"
                    '''
                }
            }
        }
    }

    post {
        always {
            junit allowEmptyResults: true, testResults: '**/target/surefire-reports/*.xml,**/target/failsafe-reports/*.xml'
            recordIssues enabledForFailure: true, tools: [
                sonarQube(),
                cargo(pattern: 'trivy.sarif'),
                checkStyle(pattern: 'checkov.sarif')
            ]
        }
        failure {
            emailext subject: "ASCEND pipeline failed: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                     body: "Build ${env.BUILD_URL} failed.",
                     to: '$DEFAULT_RECIPIENTS'
        }
    }
}
